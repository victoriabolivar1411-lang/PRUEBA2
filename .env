# CONFIGURACIÓN DE CORREO ELECTRÓNICO (SMTP / GMAIL)
#
# Para enviar correos reales (como códigos de recuperación):
# 1. Activa la "Verificación en 2 pasos" en tu cuenta de Google.
# 2. Ve a: Cuenta de Google -> Seguridad -> Contraseñas de aplicaciones.
# 3. Genera una contraseña de 16 letras para esta aplicación.
# 4. Completa los valores de abajo con tu correo y la contraseña de 16 caracteres.
#
# Si dejas estos campos vacíos, el sistema usará el backend de consola para desarrollo,
# es decir, verás el código impreso en la terminal del servidor.

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=infocentroinfocentro5@gmail.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST_PASSWORD=mpxmaftrikqsjoea

# CONFIGURACIÓN DE SMS (TWILIO)
#
# Para enviar mensajes de texto reales (SMS) al teléfono del usuario:
# 1. Crea una cuenta en Twilio (https://www.twilio.com).
# 2. Obtén tu Account SID, Auth Token y tu número de teléfono de Twilio.
# 3. Completa los valores de abajo.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# CONFIGURACIÓN DE WHATSAPP (ULTRAMSG / TWILIO)
#
# Para enviar notificaciones automáticas de WhatsApp (sin redirección manual):
#
# OPCIÓN A: UltraMsg (Recomendado, muy fácil de configurar con tu propio número)
# 1. Crea una cuenta en https://ultramsg.com
# 2. Vincula tu WhatsApp escaneando el código QR.
# 3. Copia el Instance ID y el Token que te asignan y colócalos abajo.
#
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
#
# OPCIÓN B: Twilio WhatsApp (Si usas el sandbox o número de Twilio)
# 1. Requiere que ya hayas configurado TWILIO_ACCOUNT_SID y TWILIO_AUTH_TOKEN arriba.
# 2. Coloca el número de origen de WhatsApp aprobado por Twilio abajo (con el prefijo whatsapp:).
#    Ejemplo: whatsapp:+14155238886 (sandbox) o tu número de WhatsApp aprobado de Twilio.
#
TWILIO_WHATSAPP_FROM=

# CONFIGURACIÓN DE INTELIGENCIA ARTIFICIAL (GEMINI)
#
# Para habilitar respuestas exactas a preguntas generales:
# 1. Ve a https://aistudio.google.com/ y crea una cuenta.
# 2. Genera una API Key gratuita.
# 3. Colócala abajo (si está vacía, el chatbot usará respuestas predefinidas).
GEMINI_API_KEY=
